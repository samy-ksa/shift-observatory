{
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "ksashiftobservatory.online" }],
      "destination": "https://www.ksashiftobservatory.online/:path*",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/cron/pulse",
      "schedule": "0 23 * * 0"
    }
  ]
}
